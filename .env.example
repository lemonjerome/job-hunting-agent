# Ollama Cloud API
OLLAMA_BASE_URL=https://api.ollama.com
OLLAMA_API_KEY=your-ollama-api-key-here
OLLAMA_MODEL=minimax-m2.7

# Gmail MCP OAuth credentials (JSON string or path to file)
GMAIL_CREDENTIALS=path/to/gmail_credentials.json

# Google Drive / Sheets MCP OAuth credentials (JSON string or path to file)
GDRIVE_CREDENTIALS=path/to/gdrive_credentials.json

# Your email address (for self-notifications)
SELF_EMAIL=you@example.com
