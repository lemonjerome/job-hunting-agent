# Ollama Cloud API
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=your-ollama-api-key-here
OLLAMA_MODEL=minimax-m2.7

# Path to your Google OAuth client secrets file (same file for both)
# Download from Google Cloud Console → APIs & Credentials → OAuth 2.0 Client
GMAIL_CREDENTIALS=client_secret_*.json
GDRIVE_CREDENTIALS=client_secret_*.json

# Your email address (for self-notifications)
SELF_EMAIL=you@example.com

# --- GitHub Actions secrets (set in repo Settings → Secrets, not in .env) ---
# GMAIL_CREDENTIALS_JSON  : base64 -i client_secret_*.json   | tr -d '\n'
# GDRIVE_TOKEN_JSON        : base64 -i .gdrive_token.json     | tr -d '\n'
# GMAIL_TOKEN_JSON         : base64 -i .gmail_token.json      | tr -d '\n'
# OLLAMA_BASE_URL          : https://ollama.com
# OLLAMA_API_KEY           : your-ollama-api-key-here
# SELF_EMAIL               : your@email.com
